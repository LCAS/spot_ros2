{
  "dockerFile": "../Dockerfile",
  "name": "Spot ROS2",
  "runArgs": ["--gpus=all"],
  "remoteUser": "spot",
  "containerEnv": {
    "DISPLAY": ":1.0",
    "ROS_LOCALHOST_ONLY": "0",
    "LIBGL_ALWAYS_SOFTWARE": "1"
  },
  "workspaceFolder": "/spot",
  "features": {
    "ghcr.io/devcontainers/features/desktop-lite:1": {}
  },
  "forwardPorts": [6080, 5901],
  "portsAttributes": {
    "6080": {
      "label": "novnc"
    },
    "5901": {
      "label": "vnc"
    }
  }
}
